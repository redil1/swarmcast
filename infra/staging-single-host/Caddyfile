{
	admin off
}

http://gateway {
	root * /source
	file_server
}

origin.{$SWARMCAST_PUBLIC_SUFFIX} {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}

	handle_path /live/* {
		forward_auth auth:7003 {
			uri /verify
			header_up X-Auth-Token {query.token}
		}
		root * /var/hls
		header Cache-Control "public, max-age=300, immutable"
		header Access-Control-Allow-Origin "*"
		file_server
	}

	handle_path /edge/single-host/live/* {
		forward_auth auth:7003 {
			uri /verify
			header_up X-Auth-Token {query.token}
		}
		root * /var/hls
		header Cache-Control "public, max-age=300, immutable"
		header Access-Control-Allow-Origin "*"
		file_server
	}

	handle /health {
		reverse_proxy ingest:7001
	}
}

api.{$SWARMCAST_PUBLIC_SUFFIX} {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}

	handle /token {
		reverse_proxy auth:7003
	}

	handle /jwks {
		reverse_proxy auth:7003
	}

	handle /channels* {
		reverse_proxy control-plane:7010
	}

	handle /groups* {
		reverse_proxy control-plane:7010
	}

	handle /health {
		reverse_proxy auth:7003
	}
}

tracker.{$SWARMCAST_PUBLIC_SUFFIX} {
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}

	handle /ws* {
		reverse_proxy tracker:7000
	}
}

watch.{$SWARMCAST_PUBLIC_SUFFIX} {
	encode zstd gzip

	header {
		Content-Security-Policy "default-src 'self'; connect-src 'self' https://origin.{$SWARMCAST_PUBLIC_SUFFIX} wss://tracker.{$SWARMCAST_PUBLIC_SUFFIX}; img-src 'self' data: https:; media-src 'self' blob: https://origin.{$SWARMCAST_PUBLIC_SUFFIX}; worker-src 'self' blob:; style-src 'self'; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Referrer-Policy no-referrer
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}

	reverse_proxy web:7030
}
