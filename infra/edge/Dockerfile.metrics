FROM node:22-slim

WORKDIR /app
COPY package.json package.json
COPY scripts/edge-cache-log-metrics.js scripts/edge-cache-log-metrics.js
COPY scripts/edge-cache-metrics-server.js scripts/edge-cache-metrics-server.js
RUN chown -R node:node /app

USER node
EXPOSE 9101
CMD ["node", "scripts/edge-cache-metrics-server.js"]
