      "resolved": "packages/config",
      "link": true
    },
    "node_modules/@swarmcast/control-plane": {
      "resolved": "services/control-plane",
      "link": true
    },
    "node_modules/@swarmcast/ingest": {
      "resolved": "services/ingest",
      "link": true
    },
    "node_modules/@swarmcast/p2p": {
      "resolved": "packages/p2p",
      "link": true
    },
    "node_modules/@swarmcast/retention-worker": {
      "resolved": "services/retention-worker",
      "link": true
    },
    "node_modules/@swarmcast/tracker": {
      "resolved": "services/tracker",
      "link": true
    },
    "node_modules/jose": {
      "version": "5.10.0",
      "resolved": "https://registry.npmjs.org/jose/-/jose-5.10.0.tgz",
      "integrity": "sha512-s+3Al/p9g32Iq+oqXxkW//7jk2Vig6FF1CFqzVXoTUXt2qz89YWbL+OwS17NFYEvxC35n0FKeGO2LGYSxeM2Gg==",
      "license": "MIT",
      "funding": {
        "url": "https://github.com/sponsors/panva"
      }
    },
    "node_modules/uWebSockets.js": {
      "version": "20.51.0",
      "resolved": "git+ssh://git@github.com/uNetworking/uWebSockets.js.git#6609a88ffa9a16ac5158046761356ce03250a0df",
      "license": "Apache-2.0"
    },
    "packages/config": {
      "name": "@swarmcast/config",
      "version": "0.1.0"
    },
    "packages/p2p": {
      "name": "@swarmcast/p2p",
      "version": "0.1.0"
    },
    "services/auth": {
      "name": "@swarmcast/auth",
      "version": "0.1.0",
      "dependencies": {
        "@swarmcast/config": "0.1.0",
        "jose": "^5.9.0"
      }
    },
    "services/control-plane": {
      "name": "@swarmcast/control-plane",
      "version": "0.1.0",
