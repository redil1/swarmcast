{
  "name": "swarmcast",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "swarmcast",
      "version": "0.1.0",
      "workspaces": [
        "packages/*",
        "services/*"
      ],
      "engines": {
        "node": ">=22 <24"
      }
    },
    "node_modules/@swarmcast/auth": {
      "resolved": "services/auth",
      "link": true
