      "version": "0.1.0",
      "dependencies": {
        "@swarmcast/config": "0.1.0"
      }
    },
    "services/tracker": {
      "name": "@swarmcast/tracker",
      "version": "0.1.0",
      "dependencies": {
        "@swarmcast/config": "0.1.0",
        "jose": "^5.9.0",
        "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.51.0"
