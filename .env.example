INTERNAL_TOKEN=replace-with-64-hex-chars
APP_API_KEY=replace-with-64-hex-chars
ORIGIN_BASE=https://origin.example.tv
TRACKER_BASE=wss://tracker.example.tv/ws
EDGE_BASE=https://edge.example.tv
API_BASE=https://api.example.tv
AUTH_KEY_ID=swarmcast-1
AUTH_KEY_PATH=/data/es256.pem
AUTH_PREVIOUS_JWKS_PATH=
AUTH_JWT_AUDIENCE=swarmcast
AUTH_JWT_ISSUER=swarmcast-auth
AUTH_TOKEN_TTL_SECONDS=21600
M3U_PATH=/config/source.m3u
CATALOG_DB_PATH=/data/catalog.sqlite
CATALOG_SNAPSHOT_PATH=/data/catalog-snapshot.json
PLACEMENT_DB_PATH=/data/placements.sqlite
PLACEMENT_PATH=/data/placements.json
MAX_CHANNELS=140
INGEST_NODES=[{"id":"origin","baseUrl":"https://origin.example.tv","ingestUrl":"http://ingest:7001"}]
SOURCE_ALLOWED_HOSTS=source.example.tv
SOURCE_ALLOW_PRIVATE_NETWORKS=0
P2P_MIN_SWARM_SIZE=20
TRACKER_MAX_CONNECTIONS=100000
TRACKER_MAX_PAYLOAD_BYTES=16384
TRACKER_MAX_BACKPRESSURE_BYTES=262144
TRACKER_IDLE_TIMEOUT_SECONDS=120
TRACKER_DEMAND_HEARTBEAT_SECONDS=30
TRACKER_RATE_LIMIT_CAPACITY=50
TRACKER_RATE_LIMIT_REFILL_PER_SECOND=50
TRACKER_SHARD_ID=
TRACKER_SHARDS=[]
TAIL_IDLE_TEARDOWN_MS=15000
TAIL_SWARM_THRESHOLD=5
TAIL_ADMISSION_MAX_CHANNELS=0
TAIL_DOWNSCALE_ENABLED=0
TAIL_DOWNSCALE_VIDEO_KBPS=900
TAIL_DOWNSCALE_AUDIO_KBPS=64
RETENTION_EXECUTE=0
RETENTION_STORE_MODULE=/app/scripts/retention-http-store.js
RETENTION_STORE_HTTP_BASE_URL=
RETENTION_STORE_HTTP_TOKEN=
RETENTION_STORE_HTTP_TIMEOUT_MS=10000
RETENTION_RECORDS_FILE=/data/retention-records.jsonl
ALERTMANAGER_CONFIG_PATH=/etc/swarmcast/alertmanager.yml
SWARMCAST_AUTH_IMAGE=ghcr.io/org/repo/auth@sha256:replace-with-image-digest
SWARMCAST_INGEST_IMAGE=ghcr.io/org/repo/ingest@sha256:replace-with-image-digest
SWARMCAST_TRACKER_IMAGE=ghcr.io/org/repo/tracker@sha256:replace-with-image-digest
SWARMCAST_CONTROL_PLANE_IMAGE=ghcr.io/org/repo/control-plane@sha256:replace-with-image-digest
SWARMCAST_RETENTION_WORKER_IMAGE=ghcr.io/org/repo/retention-worker@sha256:replace-with-image-digest
SWARMCAST_NGINX_IMAGE=ghcr.io/org/repo/nginx@sha256:replace-with-image-digest
SWARMCAST_PROMETHEUS_IMAGE=ghcr.io/org/repo/prometheus@sha256:replace-with-image-digest
SWARMCAST_ALERTMANAGER_IMAGE=ghcr.io/org/repo/alertmanager@sha256:replace-with-image-digest
SWARMCAST_GRAFANA_IMAGE=ghcr.io/org/repo/grafana@sha256:replace-with-image-digest
SWARMCAST_EDGE_NGINX_IMAGE=ghcr.io/org/repo/edge-nginx@sha256:replace-with-image-digest
SWARMCAST_EDGE_METRICS_IMAGE=ghcr.io/org/repo/edge-metrics@sha256:replace-with-image-digest
SWARMCAST_NODE_EXPORTER_IMAGE=ghcr.io/org/repo/node-exporter@sha256:replace-with-image-digest
